# ─────────────────────────────────────────────────────────────
# Voclira — Environment Variables
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────

# ── Moderation (Groq) ──────────────────────────────────────────
# Multilingual brand-safety classifier (llama-3.1-8b-instant)
GROQ_API_KEY=

# ── Voice AI (Fal.ai / Chatterbox) ─────────────────────────────
# FAL_KEY is read automatically by @fal-ai/client
FAL_KEY=
FAL_CHATTERBOX_TURBO_MODEL=fal-ai/chatterbox/text-to-speech/turbo
FAL_CHATTERBOX_MULTILINGUAL_MODEL=fal-ai/chatterbox/text-to-speech/multilingual

# ── Storage (Cloudflare R2, S3-compatible) ─────────────────────
# R2_ENDPOINT = https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=
R2_PRIVATE_BUCKET=
R2_PUBLIC_URL=

# ── CDN cache purge on takedown (optional) ─────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Database (Supabase / Postgres) ─────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Blockchain (Solana) ────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Platform fee wallet — receives the 10% platform cut
PLATFORM_WALLET=

# ── Rate limiting + one-time sessions (Upstash Redis) ──────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
